{
  "name": "the-brain",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm --filter @brain/api test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "seed": "pnpm --filter @brain/api seed",
    "migrate": "pnpm --filter @brain/api prisma migrate deploy",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@vercel/node": "^5.0.0",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^5.1.1",
    "prisma": "^5.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
